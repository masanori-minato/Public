////8.4.2 自動的な紐付けや連結の無効化：Qualify
//図8.4.8 Qualifyで自動的な紐付けや連結を無効化する
Qualify *;

LOAD
    年月,
    部門,
    製品名,
    金額
FROM [lib://DataFiles/実績データ.xlsx]
(ooxml, embedded labels, table is 実績データ);

LOAD
    年月,
    部門,
    金額
FROM [lib://DataFiles/予算データ.xlsx]
(ooxml, embedded labels, table is 予算データ);

Unqualify  *;


////8.4.3 テーブルデータの結合
//図8.4.10 MappingでMappingテーブルを作成
Map_Country:
Mapping LOAD
    国ID,
    国名
FROM [lib://DataFiles/国マスタ.xlsx]
(ooxml, embedded labels, table is 国マスタ);

//図8.4.11 ApplyMap関数でMappingテーブルを参照して「国ID」を「国名」に置き換え
顧客マスタ:
LOAD
    顧客名,
    ApplyMap('Map_Country',国ID,Null()) AS 国名
FROM [lib://DataFiles/顧客マスタ.xlsx]
(ooxml, embedded labels, table is 顧客マスタ);

//図8.4.13 「国マスタ」と「顧客マスタ」をJoinして結合
LOAD
    顧客名,
    国ID
FROM [lib://DataFiles/顧客マスタ.xlsx]
(ooxml, embedded labels, table is 顧客マスタ);

Join LOAD
    国ID,
    国名
FROM [lib://DataFiles/国マスタ.xlsx]
(ooxml, embedded labels, table is 国マスタ);


