////8.1.1 簡単なロードスクリプトの作成と実行
//図8.1.2 挿入されたスクリプト
LOAD
    顧客ID,
    姓,
    名,
    性別,
    血液型,
    生年月日,
    年齢
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 顧客マスタ);

LOAD
    受注日,
    顧客コード,
    購入金額
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 売上データ);

//スクリプトを修正して変換処理を追加
LOAD
    顧客ID,
    姓 & ' ' & 名 AS 氏名,
    性別,
    //血液型,
    生年月日,
    Replace(年齢, '歳', '') AS 年齢
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 顧客マスタ);

LOAD
    受注日,
    顧客コード AS 顧客ID,
    購入金額
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 売上データ);

////8.1.2 メッセージ出力やスクリプト途中での実行停止
LOAD
    顧客ID,
    姓 & ' ' & 名 AS 氏名,
    性別,
    //血液型,
    生年月日,
    Replace(年齢, '歳', '') AS 年齢
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 顧客マスタ);

Trace '顧客マスタ取り込み完了';
Exit Script;

LOAD
    受注日,
    顧客コード AS 顧客ID,
    購入金額
FROM [lib://DataFiles/売上データ.xlsx]
(ooxml, embedded labels, table is 売上データ);

